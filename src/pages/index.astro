---
// src/pages/index.astro
import HousingHistoryApp from '../components/HousingHistoryApp.jsx';
import '../styles/style.css'; 
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>🇹🇼 台灣房市簡史 1949-2026</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🇹🇼</text></svg>">
    <meta name="description" content="台灣房市簡史 1949-2026 速查互動網。">
</head>
<body>
    <header class="header" style="background: var(--surface); border-bottom: 1px solid var(--border); padding: 15px;">
      <div class="container" style="display: flex; align-items: center; gap: 10px; max-width: 800px; margin: 0 auto;">
        <div class="brand" style="display: flex; align-items: center; gap: 8px;">
          <span class="brand-icon" style="font-size: 24px;">🇹🇼</span>
          <div style="display: flex; flex-direction: column;">
            <h1 style="margin: 0; font-size: 18px; color: var(--brand);">台灣房市簡史</h1>
            <div class="subtitle" style="font-size: 12px; color: var(--text-muted);">1949-2026 歷史軌跡與房價時光機</div>
          </div>
        </div>
      </div>
    </header>

    <main style="padding-bottom: 40px;">
        <HousingHistoryApp client:load />
    </main>

    <footer class="master-footer">
        <p class="footer-copyright">版權所有©2026住宅週報,規劃設計:歐巴柴 | Copyright © 2026 HouseWeek, Design & Planning by Obachai</p>
    </footer>
</body>
</html>
